{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Microservicio EP3 - Observabilidad",
  "uid": "ep3-observabilidad",
  "tags": ["ep3", "devops", "observabilidad"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Throughput (requests/seg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"microservicio-ep3\"}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latencia p95 (segundos)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"microservicio-ep3\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Errores registrados (5xx + negocio)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"microservicio-ep3\", status=~\"5..\"}[5m])) or vector(0)",
          "legendFormat": "5xx/s"
        },
        {
          "expr": "vector(0)",
          "legendFormat": "errores negocio/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Uso de CPU del proceso (seg/seg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(process_cpu_seconds_total{job=\"microservicio-ep3\"}[5m]))",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "id": 5,
      "title": "Uso de memoria (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "decmbytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"microservicio-ep3\"} / 1024 / 1024",
          "legendFormat": "RSS MB"
        }
      ]
    },
    {
      "id": 6,
      "title": "Estado del microservicio",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "up{job=\"microservicio-ep3\"}",
          "legendFormat": "activo"
        }
      ]
    },
    {
      "id": 7,
      "title": "Solicitudes totales",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(http_requests_total{job=\"microservicio-ep3\"})",
          "legendFormat": "solicitudes"
        }
      ]
    },
    {
      "id": 8,
      "title": "Estado de Prometheus",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "expr": "up{job=\"prometheus\"}",
          "legendFormat": "prometheus"
        }
      ]
    }
  ]
}